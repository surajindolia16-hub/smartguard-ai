const express = require("express");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

/* =========================
   MODERATION QUEUE
========================= */

const queue = {
  pending: [],
  review: [],
  approved: [],
  removed: []
};

/* =========================
   HYBRID AI ENGINE (NO RANDOM)
========================= */

function analyze(text) {
  const rules = {
    severe: ["hate", "kill", "stupid", "idiot"],
    mild: ["bad", "trash", "useless"]
  };

  let score = 0;
  let matches = [];

  for (let type in rules) {
    rules[type].forEach(word => {
      if (text.toLowerCase().includes(word)) {
        score++;
        matches.push({ word, type });
      }
    });
  }

  let label = "SAFE";

  if (score >= 2) label = "TOXIC";
  else if (score === 1) label = "REVIEW";

  return {
    text,
    label,
    confidence: Math.min(0.95, 0.6 + score * 0.2),
    matches,
    explanation: {
      severe_hits: matches.filter(m => m.type === "severe").length,
      mild_hits: matches.filter(m => m.type === "mild").length
    }
  };
}

/* =========================
   DEVVIT ANALYSIS API
========================= */

app.post("/api/analyze", (req, res) => {
  const result = analyze(req.body.text);

  const item = {
    id: Date.now(),
    ...req.body,
    ...result,
    status: "PENDING"
  };

  queue.pending.unshift(item);

  res.json(item);
});

/* =========================
   MOD ACTIONS
========================= */

app.post("/api/approve", (req, res) => {
  queue.approved.push(req.body);
  res.json({ ok: true });
});

app.post("/api/remove", (req, res) => {
  queue.removed.push(req.body);
  res.json({ ok: true });
});

app.post("/api/review", (req, res) => {
  queue.review.push(req.body);
  res.json({ ok: true });
});

/* =========================
   QUEUE FETCH
========================= */

app.get("/api/queue", (req, res) => {
  res.json(queue);
});

app.listen(5000, () => {
  console.log("🚀 SmartGuard Devvit System Running");
});