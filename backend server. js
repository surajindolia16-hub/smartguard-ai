const express = require("express");
const app = express();

app.use(express.json());

/* -----------------------
   MEMORY STORE
------------------------ */

const db = {
  logs: [],
  queue: [],
  corrections: [],
  stats: {
    SAFE: 0,
    REVIEW: 0,
    TOXIC: 0,
    total: 0
  }
};

/* -----------------------
   RULES
------------------------ */

const rules = {
  high: ["hate", "kill", "stupid"],
  low: ["bad", "trash", "useless"]
};

/* -----------------------
   FIX #1: CONSISTENT LABEL ENGINE
------------------------ */

function getLabel(score) {
  if (score >= 3) return "TOXIC";
  if (score > 0) return "REVIEW";
  return "SAFE";
}

/* -----------------------
   ANALYSIS ENGINE
------------------------ */

function analyze(text) {
  const t = text.toLowerCase();

  let score = 0;
  let hits = [];

  rules.high.forEach(w => {
    if (t.includes(w)) {
      score += 2;
      hits.push(w);
    }
  });

  rules.low.forEach(w => {
    if (t.includes(w)) {
      score += 1;
      hits.push(w);
    }
  });

  const label = getLabel(score);

  /* FIX #1: proper stats update */
  db.stats[label]++;
  db.stats.total++;

  const result = {
    id: Date.now(),
    input: text,
    label,
    score,
    hits,
    confidence: Math.min(0.95, 0.6 + score * 0.1)
  };

  db.logs.push(result);

  /* FIX #3: queue separation */
  if (label === "REVIEW") {
    db.queue.push(result);
  }

  return result;
}

/* -----------------------
   FIX #4: HUMAN OVERRIDE EFFECT
------------------------ */

function applyCorrection(id, newLabel) {
  const item = db.logs.find(l => l.id === id);
  if (!item) return;

  db.stats[item.label]--;
  item.label = newLabel;
  db.stats[newLabel]++;
}

/* -----------------------
   API: ANALYZE (FIX #5 clean contract)
------------------------ */

app.post("/api/analyze", (req, res) => {
  const { text } = req.body;

  const result = analyze(text || "");

  res.json({
    success: true,
    data: result,
    meta: {
      system: "SmartGuard v15"
    }
  });
});

/* -----------------------
   MODERATION QUEUE API
------------------------ */

app.get("/api/queue", (req, res) => {
  res.json({
    count: db.queue.length,
    items: db.queue
  });
});

/* -----------------------
   DASHBOARD API (FIX #1 COMPLETE)
------------------------ */

app.get("/api/dashboard", (req, res) => {
  res.json(db.stats);
});

/* -----------------------
   CORRECTION API
------------------------ */

app.post("/api/correct", (req, res) => {
  const { id, newLabel } = req.body;

  db.corrections.push({ id, newLabel });
  applyCorrection(id, newLabel);

  res.json({ success: true });
});

app.listen(5000, () => {
  console.log("SmartGuard v15 running...");
});