const express = require("express");
const app = express();

app.use(express.json());

let logs = [];

app.post("/analyze", (req, res) => {
  const { text } = req.body;

  const score = text.length % 10; // placeholder for AI model
  const label = score > 7 ? "TOXIC" : score > 3 ? "REVIEW" : "SAFE";

  const result = {
    label,
    score,
    confidence: 0.7 + score / 20,
    explanation: "Hybrid rule-based + heuristic scoring"
  };

  logs.push(result);

  res.json({ success: true, data: result });
});

app.get("/dashboard", (req, res) => {
  res.json({
    SAFE: logs.filter(l => l.label === "SAFE").length,
    REVIEW: logs.filter(l => l.label === "REVIEW").length,
    TOXIC: logs.filter(l => l.label === "TOXIC").length,
    total: logs.length
  });
});

app.listen(5000);