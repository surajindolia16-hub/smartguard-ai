const express = require("express");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

/* =========================
   CONFIG (Human-like moderation rules)
========================= */

const rules = {
  severe: ["hate", "idiot", "stupid", "kill"],
  mild: ["bad", "useless", "trash"]
};

/* =========================
   HUMAN BEHAVIOR LAYER (IMPORTANT)
========================= */

function addHumanUncertainty(score) {
  if (score === 0) return "SAFE";
  if (score === 1) return Math.random() > 0.5 ? "FLAGGED" : "REVIEW";
  return "TOXIC";
}

/* =========================
   TEXT ANALYSIS ENGINE
========================= */

function analyze(text) {
  const clean = text.toLowerCase();

  let score = 0;
  let matched = [];

  Object.entries(rules).forEach(([type, words]) => {
    words.forEach(word => {
      if (clean.includes(word)) {
        score++;
        matched.push({ word, type });
      }
    });
  });

  let label = addHumanUncertainty(score);

  let action = "ALLOW";
  let reason = "No issues detected";

  if (label === "FLAGGED") {
    action = "WARN";
    reason = "Mild concern detected (needs context)";
  }

  if (label === "REVIEW") {
    action = "HOLD";
    reason = "Uncertain content - requires human moderator";
  }

  if (label === "TOXIC") {
    action = "BLOCK";
    reason = "High confidence toxicity detected";
  }

  return {
    input: text,
    label,
    action,
    reason,
    confidence: score === 0 ? 0.95 : 0.6,
    matches: matched,
    system: "SmartGuard Hybrid AI v2"
  };
}

/* =========================
   DEVVIT-LIKE COMMUNITY SIMULATION
========================= */

const feed = [];

const users = ["normal_user", "troll_user", "moderator"];

app.post("/api/post", (req, res) => {
  const user = users[Math.floor(Math.random() * users.length)];

  const post = {
    id: Date.now(),
    user,
    text: req.body.text,
    time: new Date().toISOString()
  };

  feed.unshift(post);

  res.json({ success: true, post });
});

app.get("/api/feed", (req, res) => {
  res.json(feed);
});

/* =========================
   MODERATION API
========================= */

app.post("/api/moderate", (req, res) => {
  const { text, userId } = req.body;

  const result = analyze(text);

  res.json({
    ...result,
    meta: {
      userId: userId || "anonymous",
      community: "devvit-simulated"
    },
    timestamp: new Date().toISOString()
  });
});

app.listen(5000, () => {
  console.log("🚀 SmartGuard AI FINAL 1% running on port 5000");
});